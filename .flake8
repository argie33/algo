[flake8]
max-line-length = 88
extend-ignore = E203, W503, E501
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    .venv,
    venv,
    node_modules,
    webapp/frontend/node_modules,
    webapp/lambda/node_modules
per-file-ignores =
    __init__.py:F401
    # Data loader scripts often have long imports
    load*.py:E402,F401
    # Scripts and main files add project root to sys.path before imports
    algo_orchestrator.py:E402
    orchestrator.py:E402
    lambda_function.py:E402
    database_context.py:E402
    dev_server.py:E402
    routes/utils.py:E402
    enrich_buy_sell_daily_technical.py:E402
    migration_helper.py:E402
    diagnose-*.py:E402
    conftest.py:E402
    test_*.py:E402
    validate_*.py:E402
    verify-*.py:E402
    panels.py:E402
    freshness.py:E402
max-complexity = 15
docstring-convention = google