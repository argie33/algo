# Prevent large files from being committed
# If a file exceeds these sizes, git will warn/error

# Reject absolutely any large binary files
*.zip filter=lfs diff=lfs merge=lfs -text
*.exe filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.tgz filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.rar filter=lfs diff=lfs merge=lfs -text

# Database dumps - warn if >10MB
*.sql merge=lfs -text
*.dump merge=lfs -text

# Media - warn if >5MB
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text

# Build outputs should be gitignored, but if they slip through:
*.so filter=lfs diff=lfs merge=lfs -text
*.a filter=lfs diff=lfs merge=lfs -text

# Node/Python build artifacts - enforce .gitignore
node_modules/ -text
__pycache__ -text
*.pyc -text
