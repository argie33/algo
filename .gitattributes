# Normalize line endings and prevent BOM in source files
* text=auto

# JavaScript/TypeScript: UTF-8 without BOM, LF line endings
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Python: LF line endings
*.py text eol=lf

# Terraform: LF line endings
*.tf text eol=lf
*.tfvars text eol=lf

# Shell scripts: LF line endings
*.sh text eol=lf

# Windows scripts: CRLF line endings
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files: no text processing
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
*.wasm binary
