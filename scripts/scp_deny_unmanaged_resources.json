{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyManualS3CreationOutsideTerraform",
      "Effect": "Deny",
      "Action": [
        "s3:CreateBucket",
        "s3:PutBucketVersioning",
        "s3:PutBucketPolicy",
        "s3:PutBucketEncryption",
        "s3:PutBucketLogging"
      ],
      "Resource": "arn:aws:s3:::*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestedRegion": "us-east-1"
        }
      }
    },
    {
      "Sid": "DenyManualLambdaCreationOutsideTerraform",
      "Effect": "Deny",
      "Action": [
        "lambda:CreateFunction",
        "lambda:CreateEventSourceMapping",
        "lambda:UpdateFunctionCode"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/terraform*"
        }
      }
    },
    {
      "Sid": "DenyManualECSClusterCreation",
      "Effect": "Deny",
      "Action": [
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecs:RegisterTaskDefinition"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/terraform*",
            "arn:aws:iam::*:role/batch*"
          ]
        }
      }
    },
    {
      "Sid": "DenyManualRDSCreation",
      "Effect": "Deny",
      "Action": [
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "rds-db:connect"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/terraform*"
        }
      }
    },
    {
      "Sid": "DenyManualEC2Creation",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateSecurityGroup",
        "ec2:CreateVpc"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/terraform*",
            "arn:aws:iam::*:role/batch*"
          ]
        }
      }
    },
    {
      "Sid": "DenyManualSecretsManagerCreation",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:PutSecretValue"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/terraform*",
            "arn:aws:iam::*:role/admin*"
          ]
        }
      }
    },
    {
      "Sid": "DenyManualIAMRoleCreation",
      "Effect": "Deny",
      "Action": [
        "iam:CreateRole",
        "iam:CreatePolicy",
        "iam:AttachRolePolicy"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:PrincipalArn": "arn:aws:iam::*:role/terraform*"
        }
      }
    },
    {
      "Sid": "DenyManualCloudFormationStack",
      "Effect": "Deny",
      "Action": [
        "cloudformation:CreateStack",
        "cloudformation:UpdateStack",
        "cloudformation:DeleteStack"
      ],
      "Resource": "*"
    },
    {
      "Sid": "RequireTerraformTagging",
      "Effect": "Deny",
      "Action": [
        "s3:PutObject",
        "s3:CreateBucket",
        "rds:CreateDBInstance",
        "ec2:RunInstances",
        "ecs:CreateCluster"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Terraform": "true"
        }
      }
    }
  ]
}
