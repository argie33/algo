NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database Configuration - update these to match your actual database
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=stocks
DB_USER=postgres
DB_PASSWORD=your-password

# AWS Configuration
AWS_REGION=us-east-1

# For local development, you might want to comment out the above and use:
