# Environment Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Local Development Database Configuration
# Use these for local development with local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stocks
DB_USER=postgres
DB_PASSWORD=password

# AWS Configuration (used in production)
# These will be set by CloudFormation/environment variables in AWS
# WEBAPP_AWS_REGION=us-east-1
# DB_SECRET_ARN=arn:aws:secretsmanager:region:account:secret:name
# DB_ENDPOINT=your-rds-endpoint.region.rds.amazonaws.com

# Note: In production deployment:
# - NODE_ENV will be set to 'prod', 'staging', or 'dev' by CloudFormation
# - DB credentials will come from AWS Secrets Manager via DB_SECRET_ARN
# - DB_ENDPOINT will be provided by CloudFormation template
# - Local .env values will be ignored in favor of Lambda environment variables
