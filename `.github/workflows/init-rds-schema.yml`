name: Initialize RDS Schema

on:
  workflow_dispatch:

jobs:
  init-db:
    runs-on: ubuntu-latest
    permissions:
      id-token: write
      contents: read
    steps:
      - uses: actions/checkout@v4

      - name: Configure AWS Credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          role-to-assume: arn:aws:iam::${{ secrets.AWS_ACCOUNT_ID }}:role/algo-svc-github-actions-dev
          aws-region: us-east-1

      - name: Create Temp Init Script
        run: |
          cat > /tmp/init_schema.py << 'EOF'
          import psycopg2
          import os

          conn = psycopg2.connect(
              host=os.getenv("DB_HOST"),
              user=os.getenv("DB_USER"),
              password=os.getenv("DB_PASSWORD"),
              database=os.getenv("DB_NAME"),
              port=5432
          )

          cursor = conn.cursor()

          # Create feature_flags table if missing
          cursor.execute("""
              CREATE TABLE IF NOT EXISTS feature_flags (
                  id SERIAL PRIMARY KEY,
                  flag_name VARCHAR(255) NOT NULL UNIQUE,
                  enabled BOOLEAN DEFAULT FALSE,
                  description TEXT,
                  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                  updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
              )
          """)

          print("✅ feature_flags table initialized")
          conn.commit()
          conn.close()
          EOF

      - name: Run DB Init via Lambda Layer
        run: |
          # Create a Lambda function to run the init script
          # We'll invoke the orchestrator with a special payload that runs init

          PAYLOAD='{"action":"init_schema"}'
          PAYLOAD_B64=$(echo -n "$PAYLOAD" | base64 -w 0)

          aws lambda invoke \
            --function-name algo-algo-dev \
            --payload "$PAYLOAD_B64" \
            --region us-east-1 \
            /tmp/init_response.json

          echo "Init Response:"
          cat /tmp/init_response.json
