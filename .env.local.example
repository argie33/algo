# ================================================================
# ENVIRONMENT VARIABLES - LOCAL DEVELOPMENT TEMPLATE
# ================================================================
# IMPORTANT: Copy this to .env.local and fill in YOUR credentials
# .env.local is .gitignored - NEVER commit it
#
# Setup: cp .env.local.example .env.local, then edit with YOUR values
# ================================================================

# ================================================================
# DATABASE CONFIGURATION
# ================================================================
# For Docker Compose (recommended):
#   DB_HOST=postgres
#   DB_PASSWORD=your-secure-local-password (not used in production)
#   DB_SSL=false
#
# For AWS RDS from local machine:
#   DB_HOST=your-rds-endpoint.rds.amazonaws.com
#   DB_PASSWORD=<fetch from AWS Secrets Manager or your vault>
#   DB_SSL=true

DB_HOST=postgres
DB_PORT=5432
DB_NAME=stocks
DB_USER=stocks
DB_PASSWORD=<YOUR_LOCAL_DB_PASSWORD>
DB_SSL=false

# Connection pool settings
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=25000

# ================================================================
# ENVIRONMENT TYPE
# ================================================================
ENVIRONMENT=local
NODE_ENV=development
PORT=3001

# ================================================================
# TRADING ALGORITHM CONFIGURATION
# ================================================================
EXECUTION_MODE=auto
ORCHESTRATOR_DRY_RUN=false
ORCHESTRATOR_LOG_LEVEL=debug
DATA_PATROL_ENABLED=true
DATA_PATROL_TIMEOUT_MS=30000

# ================================================================
# ALPACA TRADING API (Paper Trading Only)
# ================================================================
# Get credentials from https://app.alpaca.markets (paper trading account)
# NEVER use live trading credentials in development
# Fetch from: AWS Secrets Manager or your local vault
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_API_KEY_ID=<FETCH_FROM_VAULT>
APCA_API_SECRET_KEY=<FETCH_FROM_VAULT>
ALPACA_PAPER_TRADING=true

# ================================================================
# AWS CONFIGURATION
# ================================================================
AWS_REGION=us-east-1

# For local development:
# - If using Docker: leave these unset, use IAM role
# - If accessing AWS from local machine: configure AWS CLI instead
#   aws configure  # Sets credentials in ~/.aws/credentials
# Do NOT put AWS credentials here
# AWS_ACCESS_KEY_ID=<DO_NOT_COMMIT>
# AWS_SECRET_ACCESS_KEY=<DO_NOT_COMMIT>

# ================================================================
# FINANCIAL DATA SOURCES (Optional for local testing)
# ================================================================
FRED_API_KEY=<OPTIONAL>
ALPHA_VANTAGE_API_KEY=<OPTIONAL>
POLYGON_API_KEY=<OPTIONAL>
QUANDL_API_KEY=<OPTIONAL>

# ================================================================
# EMAIL & ALERTING
# ================================================================
ALERT_EMAIL_TO=your-email@example.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=<YOUR_EMAIL>
ALERT_SMTP_PASSWORD=<YOUR_APP_PASSWORD>
ALERT_SNS_TOPIC_ARN=<OPTIONAL>

# ================================================================
# FRONTEND & WEB
# ================================================================
FRONTEND_URL=http://localhost:5173
WEBSITE_URL=http://localhost:5173
API_STAGE=dev

# ================================================================
# AUTHENTICATION
# ================================================================
LOCAL_DEV_MODE=true
ALLOW_DEV_BYPASS=true
JWT_SECRET=<USE_STRONG_RANDOM_STRING_FOR_LOCAL>

# ================================================================
# PGADMIN (optional, for docker-compose UI)
# ================================================================
PGADMIN_EMAIL=admin@localhost
PGADMIN_PASSWORD=<YOUR_LOCAL_PASSWORD_ONLY>
