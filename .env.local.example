# ================================================================
# ENVIRONMENT VARIABLES - LOCAL DEVELOPMENT TEMPLATE
# ================================================================
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# .env.local is .gitignored and should NEVER be committed
#
# For AWS Production: Use AWS Secrets Manager + Lambda environment variables
# For Local Development: Use this .env.local file
# ================================================================

# ================================================================
# DATABASE CONFIGURATION - LOCAL DEVELOPMENT
# ================================================================
# When using docker-compose.local.yml:
#   - DB_HOST=postgres (docker service name)
#   - DB_PORT=5432 (exposed by docker-compose)
#   - DB_NAME=stocks (matches POSTGRES_DB)
#   - DB_USER=stocks (matches POSTGRES_USER)
#   - DB_PASSWORD=your-secure-password (matches POSTGRES_PASSWORD)
#
# When using AWS RDS in development:
#   - DB_HOST=your-rds-endpoint.rds.amazonaws.com
#   - DB_PORT=5432 (RDS port)
#   - DB_NAME=stocks (RDS DBName parameter)
#   - DB_USER=stocks (RDS MasterUsername parameter)
#   - DB_PASSWORD=your-rds-master-password (RDS MasterUserPassword)
#   - DB_SSL=true (recommended for RDS over the internet)

# Local PostgreSQL via docker-compose
DB_HOST=postgres
DB_PORT=5432
DB_NAME=stocks
DB_USER=stocks
DB_PASSWORD=your-secure-local-password-here

# Connection settings (same for local and AWS)
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECT_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=25000

# ================================================================
# ENVIRONMENT TYPE
# ================================================================
# Values: 'local' | 'development' | 'staging' | 'production'
ENVIRONMENT=local

# Node runtime
NODE_ENV=development
PORT=3001

# ================================================================
# TRADING ALGORITHM CONFIGURATION
# ================================================================
# Execution Mode
EXECUTION_MODE=paper

# Data patrol settings
DATA_PATROL_ENABLED=true
DATA_PATROL_TIMEOUT_MS=30000

# Orchestrator settings
ORCHESTRATOR_DRY_RUN=true
ORCHESTRATOR_LOG_LEVEL=debug

# ================================================================
# ALPACA TRADING API (Paper Trading)
# ================================================================
# DO NOT use real money credentials in development
# Get paper trading credentials from https://app.alpaca.markets/
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_API_KEY_ID=YOUR_PAPER_API_KEY_ID
APCA_API_SECRET_KEY=YOUR_PAPER_API_SECRET_KEY
ALPACA_PAPER_TRADING=true
PORTFOLIO_USER_ID=paper-user

# ================================================================
# AWS CONFIGURATION
# ================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ================================================================
# FINANCIAL DATA API KEYS
# ================================================================
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
QUANDL_API_KEY=

# ================================================================
# EMAIL & ALERTING
# ================================================================
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=argeropolos@gmail.com
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ALERT_SNS_TOPIC_ARN=

# ================================================================
# FRONTEND CONFIGURATION
# ================================================================
FRONTEND_URL=http://localhost:5173
WEBSITE_URL=http://localhost:5173
API_STAGE=dev

# ================================================================
# AUTHENTICATION
# ================================================================
LOCAL_DEV_MODE=true
ALLOW_DEV_BYPASS=true
JWT_SECRET=development-jwt-secret-change-in-production
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# ================================================================
# PGADMIN (docker-compose)
# ================================================================
PGADMIN_EMAIL=admin@stocks.local
PGADMIN_PASSWORD=admin
