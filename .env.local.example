# Local Development Environment Configuration
# Copy to .env.local and fill in values for local development

# === Database (local) ===
DB_HOST=localhost
DB_PORT=5432
DB_USER=stocks
DB_PASSWORD=stocks_local_password
DB_NAME=stocks

# === Database (AWS RDS) - uncomment to use production database ===
# DB_HOST=<RDS_ENDPOINT>
# DB_USER=<RDS_USERNAME>
# DB_PASSWORD=<RDS_PASSWORD>
# DB_NAME=stocks
# DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:<ACCOUNT_ID>:secret:stocks-db-secret
# AWS_REGION=us-east-1

# === API Keys ===
FRED_API_KEY=your_fred_api_key_here
ALPACA_API_KEY_ID=your_alpaca_api_key_id
ALPACA_API_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === AWS (Local via LocalStack) ===
# Use LocalStack for local development
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566

# === S3 ===
S3_STAGING_BUCKET=stocks-app-data
S3_ENDPOINT_URL=http://localhost:4566

# === Logging ===
LOG_LEVEL=INFO

# === Development Mode ===
# Set to 'true' to use LocalStack instead of AWS
USE_LOCALSTACK=true
USE_S3_STAGING=false
