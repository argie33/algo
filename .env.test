# Test environment variables
# Copy to .env.local and customize for your test database

# Test database (create stocks_test database before running tests)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=stocks_test
TEST_DB_USER=stocks
TEST_DB_PASSWORD=

# Alpaca (mocked in tests, but configure for manual integration testing)
APCA_API_KEY_ID=test_key_do_not_use
APCA_API_SECRET_KEY=test_secret_do_not_use
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Algo configuration
EXECUTION_MODE=paper
ENABLE_ALGO=true
VERBOSE_LOGGING=true

# Alerts (optional)
# EMAIL_RECIPIENT=
# ALERT_SNS_TOPIC_ARN=
