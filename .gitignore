# Dependencies
node_modules/
**/node_modules/
package-lock.json
# EXCEPTION: Production package-lock.json files must be tracked for deployments
!webapp/lambda/package-lock.json
!webapp/frontend/package-lock.json

# Build outputs
dist/
**/dist/
build/
**/build/
.next/
out/

# Build artifacts
*.zip
*.tar.gz
*.tgz
function.zip
lambda-package.zip
lambda-deployment.tar.gz

# Database
*.db
*.sqlite
*.sql
!init_db.sql
!terraform/modules/database/init.sql
!lambda/db-init/schema.sql

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment — NEVER commit these files
# Root level env files
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local
.env.vault
# Subdirectory env files
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.staging
**/.env.test
**/.env.*.local
**/.env.vault
# But DO commit template/example files
!.env.example
!.env.*.example
!.env.local.example
!.env.vault.template
!**/.env.example
!**/.env.*.example
!**/.env.local.example

