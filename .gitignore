# Dependencies
node_modules/
**/node_modules/
package-lock.json
# EXCEPTION: Lambda package-lock.json must be tracked for AWS deployment
!webapp/lambda/package-lock.json

# Build outputs
dist/
**/dist/
build/
**/build/
.next/
out/

# Build artifacts
*.zip
*.tar.gz
*.tgz
function.zip
lambda-package.zip
lambda-deployment.tar.gz

# Database
*.db
*.sqlite
*.sql
!init_db.sql
!terraform/modules/database/init.sql
!lambda/db-init/schema.sql

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment — NEVER commit these files
# Root level env files
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local
.env.vault
# Subdirectory env files
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.staging
**/.env.test
**/.env.*.local
**/.env.vault
# But DO commit template/example files
!.env.example
!.env.*.example
!.env.local.example
!.env.vault.template
!**/.env.example
!**/.env.*.example
!**/.env.local.example

# Testing
coverage/
.nyc_output/
test-results/
playwright-report/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary
*.tmp
*.temp
__pycache__/
venv*/
*.py[cod]

# Runtime artifacts (local-only)
.algo_orchestrator.lock
*_orchestrator.lock
paper_mode_reports/
.loader-progress.json

# SAM build outputs
.aws-sam/
**/lambda-build/
.sam-tests/

# Terraform (IaC)
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
**/.terraform.local/
terraform.tfvars.local
override.tf
override.tf.json
*_override.tf
*_override.tf.json
tfplan
*.tfplan

# Serverless Framework
.serverless/
**/serverless-state.json

# Large binary files
*.msi
*.exe
*.dmg
*.pkg
*.deb
*.rpm

# AWS artifacts
AWSCLIV2.*
aws-cli-*.zip

# Sensitive (local development only)
!.env.local.example  # Template is tracked, actual .env.local is not

# Generated files
DEPLOYMENT_IN_PROGRESS.md
.watermarks/

# Documentation sprawl prevention
# (Session snapshots, dated audits, temporary docs)
SESSION_SUMMARY_*.md
FINAL_*.md
VERIFICATION_COMPLETE_*.md
*_2026_*.md
ARCHIVE_SNAPSHOTS/
SESSIONS_COMPLETED/
DECISIONS_RATIONALE/
DESIGNS_DEPRECATED/
.docs_archive/
.consolidation_plan.md

# GitHub Actions build artifacts
lambda-pkg/
db-init-pkg/
