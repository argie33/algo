# Dockerfile.buyselldaily

# 1) Base image
FROM python:3.10-slim

# 2) Where we'll live inside the container
WORKDIR /app

# 3) Install OS-level build tools for psutil and performance packages
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential && \
    rm -rf /var/lib/apt/lists/*

# 4) Copy & install Python deps
COPY requirements-loadbuyselldaily.txt .
RUN pip install --upgrade pip \
 && pip install --no-cache-dir -r requirements-loadbuyselldaily.txt

# 5) Copy your loader
COPY loadbuyselldaily.py .

# 6) Command
CMD ["python", "loadbuyselldaily.py"]
