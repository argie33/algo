{
  "name": "institutional-hft-system",
  "version": "1.0.0",
  "description": "Ultra-low latency institutional-grade high-frequency trading system",
  "main": "dist/main.js",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main-hft.ts",
    "build": "tsc && npm run optimize",
    "start": "node --max-old-space-size=8192 --optimize-for-size --gc-interval=100 dist/main.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:hft": "tsx src/test-hft-core.ts",
    "benchmark": "tsx scripts/benchmark.ts",
    "optimize": "terser dist/**/*.js --compress --mangle --output dist/",
    "docker:build": "docker build -t hft-system .",
    "docker:run": "docker-compose up",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@alpacahq/alpaca-trade-api": "^3.0.3",
    "@types/node": "^20.10.0",
    "axios": "^1.6.2",
    "decimal.js": "^10.4.3",
    "flatbuffers": "^23.5.26",
    "ioredis": "^5.3.2",
    "kafkajs": "^2.2.4",
    "msgpackr": "^1.10.1",
    "node-cron": "^3.0.3",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "ws": "^8.14.2",
    "uuid": "^9.0.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "terser": "^5.24.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "hft",
    "high-frequency-trading",
    "algorithmic-trading",
    "market-data",
    "ultra-low-latency",
    "institutional",
    "hedge-fund",
    "typescript",
    "nodejs"
  ]
}
