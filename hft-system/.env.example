# HFT System Environment Configuration

# Environment
NODE_ENV=development
LOG_LEVEL=info

# Alpaca Configuration
ALPACA_KEY_ID=your_alpaca_key_id
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=wss://stream.data.alpaca.markets/v2/iex
ALPACA_PAPER=true

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hft_system
DB_USER=hft_user
DB_PASSWORD=your_db_password
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100

# Risk Management
MAX_POSITION_SIZE=100000
MAX_PORTFOLIO_VALUE=1000000
MAX_DAILY_LOSS=10000
MAX_DRAWDOWN=0.05
CONCENTRATION_LIMIT=0.2
LEVERAGE_LIMIT=2.0
MAX_ORDER_SIZE=10000

# Performance Targets
MAX_LATENCY_MS=20
MAX_ORDER_PROCESSING_MS=5
TARGET_THROUGHPUT=10000
TARGET_UPTIME=0.9999

# AWS Configuration
AWS_REGION=us-east-1
AWS_SECRETS_PREFIX=hft-system
CLOUDWATCH_NAMESPACE=HFT-System

# Monitoring
HEALTH_CHECK_INTERVAL=5000
METRICS_INTERVAL=1000
ALERT_LATENCY_MS=50
ALERT_ERROR_RATE=0.01
ALERT_MEMORY_USAGE=0.8

# Trading Hours
TRADING_START=09:30
TRADING_END=16:00
TRADING_TIMEZONE=America/New_York

# Trading Symbols (JSON format)
# TRADING_SYMBOLS=[{"symbol":"SPY","exchange":"ARCA","assetClass":"etf","enabled":true,"maxPositionSize":50000,"tickSize":0.01,"multiplier":1}]
