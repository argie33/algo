{
  "widgets": [
    {
      "type": "metric",
      "properties": {
        "metrics": [
          ["Algo/FailFast", "DataUnavailableErrors", {"stat": "Sum"}],
          [".", "ValidationErrors", {"stat": "Sum"}],
          [".", "CircuitBreakerHalts", {"stat": "Sum"}],
          [".", "DataStalenessErrors", {"stat": "Sum"}],
          [".", "HardeningErrors", {"stat": "Sum"}]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "title": "Phase 4: Fail-Fast Error Patterns",
        "period": 300,
        "yAxis": {"left": {"min": 0}},
        "annotations": {
          "horizontal": [
            {"label": "Data Unavail Threshold", "value": 5},
            {"label": "Validation Error Threshold", "value": 10},
            {"label": "Circuit Breaker Threshold", "value": 1}
          ]
        }
      },
      "width": 24,
      "height": 6,
      "x": 0,
      "y": 0
    },
    {
      "type": "metric",
      "properties": {
        "metrics": [["Algo/FailFast", "AllErrors", {"stat": "Sum"}]],
        "view": "singleValue",
        "region": "us-east-1",
        "title": "Total Errors (Last 5 min)",
        "period": 300
      },
      "width": 6,
      "height": 3,
      "x": 0,
      "y": 6
    },
    {
      "type": "metric",
      "properties": {
        "metrics": [["Algo/FailFast", "CircuitBreakerHalts", {"stat": "Sum"}]],
        "view": "singleValue",
        "region": "us-east-1",
        "title": "Circuit Breaker Halts",
        "period": 300
      },
      "width": 6,
      "height": 3,
      "x": 6,
      "y": 6
    },
    {
      "type": "metric",
      "properties": {
        "metrics": [["Algo/FailFast", "DataUnavailableErrors", {"stat": "Average"}]],
        "view": "singleValue",
        "region": "us-east-1",
        "title": "Avg Data Unavailable/min",
        "period": 300
      },
      "width": 6,
      "height": 3,
      "x": 12,
      "y": 6
    },
    {
      "type": "metric",
      "properties": {
        "metrics": [["Algo/FailFast", "ValidationErrors", {"stat": "Average"}]],
        "view": "singleValue",
        "region": "us-east-1",
        "title": "Avg Validation Errors/min",
        "period": 300
      },
      "width": 6,
      "height": 3,
      "x": 18,
      "y": 6
    },
    {
      "type": "metric",
      "properties": {
        "metrics": [
          ["Algo/FailFast", "DataUnavailableErrors", {"stat": "Sum"}],
          [".", "ValidationErrors", {"stat": "Sum"}],
          [".", "CircuitBreakerHalts", {"stat": "Sum"}],
          [".", "DataStalenessErrors", {"stat": "Sum"}],
          [".", "HardeningErrors", {"stat": "Sum"}]
        ],
        "view": "pie",
        "region": "us-east-1",
        "title": "Error Type Distribution (Last 1 hour)",
        "period": 3600
      },
      "width": 12,
      "height": 6,
      "x": 0,
      "y": 9
    },
    {
      "type": "log",
      "properties": {
        "query": "fields @timestamp, @message | filter @message like /\\[FAIL_FAST\\]/ | stats count() as failures by bin(5m)",
        "region": "us-east-1",
        "title": "Data Unavailable Events (Logs Insights)"
      },
      "width": 12,
      "height": 6,
      "x": 12,
      "y": 9
    },
    {
      "type": "log",
      "properties": {
        "query": "fields @timestamp, @message | filter @message like /\\[CIRCUIT_BREAKER\\]/ and @message like /HALTING TRADING/ | stats count() as halts",
        "region": "us-east-1",
        "title": "Circuit Breaker Halt Events"
      },
      "width": 12,
      "height": 6,
      "x": 0,
      "y": 15
    },
    {
      "type": "log",
      "properties": {
        "query": "fields @timestamp, @message | filter @message like /\\[HARDENING\\]/ and @message like /(validation|error)/ | stats count() as validation_errors by bin(5m)",
        "region": "us-east-1",
        "title": "Validation Error Timeline"
      },
      "width": 12,
      "height": 6,
      "x": 12,
      "y": 15
    },
    {
      "type": "log",
      "properties": {
        "query": "fields @timestamp, @message, @logStream | filter @message like /error|ERROR|Exception/ | stats count() as error_count by @logStream | sort error_count desc",
        "region": "us-east-1",
        "title": "Error Count by Lambda Function"
      },
      "width": 24,
      "height": 6,
      "x": 0,
      "y": 21
    }
  ]
}
