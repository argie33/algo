FROM python:3.11-slim

WORKDIR /app

# Install system dependencies for faster compilation
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY requirements-loadtechnicalsweeklyfast.txt .
RUN pip install --no-cache-dir -r requirements-loadtechnicalsweeklyfast.txt

# Copy the script
COPY loadtechnicalsweeklyfast.py .

# Run the script
CMD ["python", "loadtechnicalsweeklyfast.py"]
